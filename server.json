{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.deduu/mcp-tuna",
  "description": "MCP server suite for LLM fine-tuning workflows: generate datasets, evaluate quality, train adapters, and deploy models.",
  "status": "active",
  "repository": {
    "url": "https://github.com/deduu/MCP-Tuna",
    "source": "github"
  },
  "version": "0.2.0",
  "website_url": "https://github.com/deduu/MCP-Tuna",
  "packages": [
    {
      "registry_type": "pypi",
      "registry_base_url": "https://pypi.org",
      "identifier": "mcp-tuna",
      "version": "0.2.0",
      "transport": {
        "type": "stdio"
      },
      "runtime_hint": "uvx",
      "runtime_arguments": [
        {
          "type": "named",
          "name": "--from",
          "value": "mcp-tuna[all-servers]"
        }
      ],
      "package_arguments": [
        {
          "type": "positional",
          "value": "mcp-tuna-gateway"
        }
      ],
      "environment_variables": [
        {
          "name": "OPENAI_API_KEY",
          "description": "OpenAI API key for generation and evaluation features.",
          "is_required": false,
          "is_secret": true,
          "format": "string"
        },
        {
          "name": "HF_TOKEN",
          "description": "HuggingFace token for model download, upload, and hosting workflows.",
          "is_required": false,
          "is_secret": true,
          "format": "string"
        }
      ]
    }
  ]
}
