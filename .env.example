# =============================================================================
# MCP Tuna Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Providers ----------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=              # Optional: custom endpoint (e.g., for Azure)
OPENAI_MODEL=gpt-4o           # Default model for pipelines

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_BASE=           # Optional: custom endpoint

GOOGLE_API_KEY=...

# --- HuggingFace ------------------------------------------------------------
HF_TOKEN=hf_...               # Required for gated models + push_to_hub

# --- Database ----------------------------------------------------------------
DB_DRIVER=postgresql+asyncpg
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dbname
DB_USER=user
DB_PASSWORD=password
PERSISTENCE_ENABLED=true

# --- Object Storage ----------------------------------------------------------
OBJECT_STORAGE_ENABLED=false
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=mcp-tuna
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_SECURE=false
OBJECT_STORAGE_PREFIX=dev
OBJECT_STORAGE_PUBLIC_URL=
OBJECT_STORAGE_AUTO_CREATE_BUCKET=true
OBJECT_STORAGE_PRESERVE_LOCAL_FILES=true

# --- Email -------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER=

# --- MCP Server URLs ---------------------------------------------------------
MCP_TUNA_GATEWAY_PORT=8002  # MCP Tuna unified gateway
DB_MCP_URL=http://localhost:8002/mcp
EMAIL_MCP_URL=http://localhost:8003/mcp
FILE_MCP_URL=http://localhost:8004/mcp
WEB_MCP_URL=http://localhost:8005/mcp
MCP_AUTO_CONNECT=false         # Auto-connect to MCP servers on agent creation

# --- File Uploads ------------------------------------------------------------
UPLOAD_ROOT=./uploads

# --- Tracing (optional) ------------------------------------------------------
AUDITI_API_KEY=
